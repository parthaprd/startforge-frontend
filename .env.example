# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe Public Key
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# ImgBB API Key (for image uploads handled by backend)
NEXT_PUBLIC_IMGBB_API_KEY=your_imgbb_api_key

# Environment
NODE_ENV=development

# BetterAuth Configuration (for self-hosted auth)
MONGODB_URI=mongodb://localhost:27017/startupforge
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long